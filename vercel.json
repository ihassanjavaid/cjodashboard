{
  "redirects": [
    {
      "source": "/",
      "destination": "/new-ui",
      "permanent": false
    }
  ],
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/sync", "schedule": "0 6 * * 1" }
  ],
  "rewrites": [
    { "source": "/((?!api/|@|src/|node_modules/|assets/|favicon\\.svg|.+\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
